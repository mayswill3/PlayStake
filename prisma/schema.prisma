// =============================================================================
// PlayStake - Complete Prisma Schema
// =============================================================================
// Double-entry ledger pattern for all money movement.
// UUIDs for all public-facing IDs.
// Soft deletes where business rules require audit trails.
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  PLAYER
  DEVELOPER
  ADMIN
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BET_ESCROW
  BET_ESCROW_RELEASE
  BET_ESCROW_REFUND
  PLATFORM_FEE
  DEVELOPER_SHARE
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum LedgerAccountType {
  PLAYER_BALANCE
  DEVELOPER_BALANCE
  ESCROW
  PLATFORM_REVENUE
  STRIPE_SOURCE
  STRIPE_SINK
}

enum BetStatus {
  PENDING_CONSENT
  OPEN
  MATCHED
  RESULT_REPORTED
  SETTLED
  CANCELLED
  DISPUTED
  VOIDED
}

enum BetOutcome {
  PLAYER_A_WIN
  PLAYER_B_WIN
  DRAW
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_PLAYER_A
  RESOLVED_PLAYER_B
  RESOLVED_DRAW
  RESOLVED_VOID
}

enum WebhookEventType {
  BET_CREATED
  BET_MATCHED
  BET_RESULT_REPORTED
  BET_SETTLED
  BET_CANCELLED
  BET_DISPUTED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}

enum WidgetSessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum AnomalyType {
  SKEWED_WIN_RATE
  RAPID_BET_SETTLEMENT
  SINGLE_WINNER_PATTERN
  HIGH_VOLUME_SPIKE
  RESULT_HASH_MISMATCH
}

enum AnomalyStatus {
  DETECTED
  INVESTIGATING
  CONFIRMED_FRAUD
  FALSE_POSITIVE
  RESOLVED
}

// =============================================================================
// USER & AUTH
// =============================================================================

model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String    @unique @db.VarChar(255)
  passwordHash      String?   @map("password_hash") @db.VarChar(255)
  role              UserRole  @default(PLAYER)
  displayName       String    @map("display_name") @db.VarChar(100)
  avatarUrl         String?   @map("avatar_url") @db.VarChar(500)
  kycStatus         KycStatus @default(NOT_STARTED) @map("kyc_status")
  stripeCustomerId  String?   @unique @map("stripe_customer_id") @db.VarChar(255)
  emailVerified     Boolean   @default(false) @map("email_verified")
  twoFactorEnabled  Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret   String?   @map("two_factor_secret") @db.VarChar(255)
  lastLoginAt       DateTime? @map("last_login_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  // Relations
  ledgerAccounts    LedgerAccount[]
  sessionsAsPlayerA Bet[]            @relation("PlayerA")
  sessionsAsPlayerB Bet[]            @relation("PlayerB")
  disputesFiled     Dispute[]        @relation("DisputeFiler")
  disputeMessages   DisputeMessage[]
  developerProfile  DeveloperProfile?
  widgetSessions    WidgetSession[]
  sessions          Session[]
  oauthAccounts     OAuthAccount[]

  @@index([email], map: "idx_user_email")
  @@index([stripeCustomerId], map: "idx_user_stripe_customer")
  @@index([role], map: "idx_user_role")
  @@index([createdAt], map: "idx_user_created_at")
  @@map("users")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  tokenHash    String   @unique @map("token_hash") @db.VarChar(255)
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId], map: "idx_session_user")
  @@index([expiresAt], map: "idx_session_expires")
  @@map("sessions")
}

model OAuthAccount {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  provider       String   @db.VarChar(50)
  providerUserId String   @map("provider_user_id") @db.VarChar(255)
  email          String?  @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId], map: "uq_oauth_provider_user")
  @@index([userId], map: "idx_oauth_user")
  @@map("oauth_accounts")
}

// =============================================================================
// DEVELOPER / GAME REGISTRATION
// =============================================================================

model DeveloperProfile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  companyName     String   @map("company_name") @db.VarChar(255)
  websiteUrl      String?  @map("website_url") @db.VarChar(500)
  contactEmail    String   @map("contact_email") @db.VarChar(255)
  revSharePercent Decimal  @default(0) @map("rev_share_percent") @db.Decimal(5, 4)
  isApproved      Boolean  @default(false) @map("is_approved")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user         User                  @relation(fields: [userId], references: [id])
  games        Game[]
  apiKeys      ApiKey[]
  escrowLimit  DeveloperEscrowLimit?

  @@map("developer_profiles")
}

model Game {
  id                 String   @id @default(uuid()) @db.Uuid
  developerProfileId String   @map("developer_profile_id") @db.Uuid
  name               String   @db.VarChar(255)
  slug               String   @unique @db.VarChar(255)
  description        String?  @db.Text
  logoUrl            String?  @map("logo_url") @db.VarChar(500)
  webhookUrl         String?  @map("webhook_url") @db.VarChar(500)
  webhookSecret      String?  @map("webhook_secret") @db.VarChar(255)
  isActive           Boolean  @default(true) @map("is_active")
  maxBetAmount       Decimal  @default(1000) @map("max_bet_amount") @db.Decimal(12, 2)
  minBetAmount       Decimal  @default(1) @map("min_bet_amount") @db.Decimal(12, 2)
  platformFeePercent Decimal  @default(0.05) @map("platform_fee_percent") @db.Decimal(5, 4)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  developerProfile DeveloperProfile @relation(fields: [developerProfileId], references: [id])
  bets             Bet[]
  webhookConfigs   WebhookConfig[]

  @@index([developerProfileId], map: "idx_game_developer")
  @@index([slug], map: "idx_game_slug")
  @@index([isActive], map: "idx_game_active")
  @@map("games")
}

model ApiKey {
  id                 String    @id @default(uuid()) @db.Uuid
  developerProfileId String    @map("developer_profile_id") @db.Uuid
  keyPrefix          String    @map("key_prefix") @db.VarChar(8)
  keyHash            String    @unique @map("key_hash") @db.VarChar(255)
  label              String    @db.VarChar(100)
  permissions        String[]  @default(["bet:create", "bet:read", "result:report"])
  isActive           Boolean   @default(true) @map("is_active")
  lastUsedAt         DateTime? @map("last_used_at")
  expiresAt          DateTime? @map("expires_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  revokedAt          DateTime? @map("revoked_at")

  developerProfile DeveloperProfile @relation(fields: [developerProfileId], references: [id])

  @@index([keyHash], map: "idx_apikey_hash")
  @@index([developerProfileId], map: "idx_apikey_developer")
  @@map("api_keys")
}

// =============================================================================
// DOUBLE-ENTRY LEDGER
// =============================================================================

model LedgerAccount {
  id          String            @id @default(uuid()) @db.Uuid
  userId      String?           @map("user_id") @db.Uuid
  betId       String?           @map("bet_id") @db.Uuid
  accountType LedgerAccountType @map("account_type")
  balance     Decimal           @default(0) @db.Decimal(14, 2)
  currency    String            @default("USD") @db.VarChar(3)
  frozen      Boolean           @default(false)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  user    User?         @relation(fields: [userId], references: [id])
  bet     Bet?          @relation(fields: [betId], references: [id])
  entries LedgerEntry[]

  @@unique([userId, accountType], map: "uq_user_account_type")
  @@index([accountType], map: "idx_ledger_account_type")
  @@index([userId], map: "idx_ledger_account_user")
  @@index([betId], map: "idx_ledger_account_bet")
  @@map("ledger_accounts")
}

model LedgerEntry {
  id              String  @id @default(uuid()) @db.Uuid
  ledgerAccountId String  @map("ledger_account_id") @db.Uuid
  transactionId   String  @map("transaction_id") @db.Uuid
  amount          Decimal @db.Decimal(14, 2)
  balanceAfter    Decimal @map("balance_after") @db.Decimal(14, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  ledgerAccount LedgerAccount @relation(fields: [ledgerAccountId], references: [id])
  transaction   Transaction   @relation(fields: [transactionId], references: [id])

  @@index([ledgerAccountId, createdAt], map: "idx_entry_account_time")
  @@index([transactionId], map: "idx_entry_transaction")
  @@map("ledger_entries")
}

model Transaction {
  id              String            @id @default(uuid()) @db.Uuid
  idempotencyKey  String            @unique @map("idempotency_key") @db.VarChar(255)
  type            TransactionType
  status          TransactionStatus @default(PENDING)
  amount          Decimal           @db.Decimal(14, 2)
  currency        String            @default("USD") @db.VarChar(3)
  description     String?           @db.VarChar(500)
  metadata        Json?
  betId           String?           @map("bet_id") @db.Uuid
  stripePaymentId String?           @map("stripe_payment_id") @db.VarChar(255)
  failureReason   String?           @map("failure_reason") @db.VarChar(500)
  completedAt     DateTime?         @map("completed_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  bet     Bet?          @relation(fields: [betId], references: [id])
  entries LedgerEntry[]

  @@index([type, status], map: "idx_txn_type_status")
  @@index([betId], map: "idx_txn_bet")
  @@index([stripePaymentId], map: "idx_txn_stripe")
  @@index([createdAt], map: "idx_txn_created")
  @@index([idempotencyKey], map: "idx_txn_idempotency")
  @@map("transactions")
}

// =============================================================================
// BETS / MATCHES
// =============================================================================

model Bet {
  id                   String      @id @default(uuid()) @db.Uuid
  externalId           String?     @unique @map("external_id") @db.VarChar(255)
  gameId               String      @map("game_id") @db.Uuid
  playerAId            String      @map("player_a_id") @db.Uuid
  playerBId            String?     @map("player_b_id") @db.Uuid
  amount               Decimal     @db.Decimal(12, 2)
  currency             String      @default("USD") @db.VarChar(3)
  status               BetStatus   @default(PENDING_CONSENT)
  outcome              BetOutcome?
  platformFeePercent   Decimal     @map("platform_fee_percent") @db.Decimal(5, 4)
  platformFeeAmount    Decimal?    @map("platform_fee_amount") @db.Decimal(12, 2)
  gameMetadata         Json?       @map("game_metadata")
  resultPayload        Json?       @map("result_payload")
  resultReportedAt     DateTime?   @map("result_reported_at")
  resultIdempotencyKey String?     @unique @map("result_idempotency_key") @db.VarChar(255)
  serverResultHash     String?     @map("server_result_hash") @db.VarChar(255)
  widgetResultHash     String?     @map("widget_result_hash") @db.VarChar(255)
  resultVerified       Boolean     @default(false) @map("result_verified")
  playerAConsentedAt   DateTime?   @map("player_a_consented_at")
  playerBConsentedAt   DateTime?   @map("player_b_consented_at")
  matchedAt            DateTime?   @map("matched_at")
  settledAt            DateTime?   @map("settled_at")
  cancelledAt          DateTime?   @map("cancelled_at")
  expiresAt            DateTime    @map("expires_at")
  consentExpiresAt     DateTime?   @map("consent_expires_at")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  game            Game                 @relation(fields: [gameId], references: [id])
  playerA         User                 @relation("PlayerA", fields: [playerAId], references: [id])
  playerB         User?                @relation("PlayerB", fields: [playerBId], references: [id])
  transactions    Transaction[]
  disputes        Dispute[]
  escrowAccounts  LedgerAccount[]
  webhookLogs     WebhookDeliveryLog[]

  @@index([gameId, status], map: "idx_bet_game_status")
  @@index([playerAId, status], map: "idx_bet_player_a_status")
  @@index([playerBId, status], map: "idx_bet_player_b_status")
  @@index([status, expiresAt], map: "idx_bet_status_expires")
  @@index([createdAt], map: "idx_bet_created")
  @@index([externalId], map: "idx_bet_external")
  @@map("bets")
}

// =============================================================================
// DISPUTES
// =============================================================================

model Dispute {
  id           String        @id @default(uuid()) @db.Uuid
  betId        String        @map("bet_id") @db.Uuid
  filedById    String        @map("filed_by_id") @db.Uuid
  status       DisputeStatus @default(OPEN)
  reason       String        @db.Text
  resolution   String?       @db.Text
  resolvedById String?       @map("resolved_by_id") @db.Uuid
  resolvedAt   DateTime?     @map("resolved_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  bet      Bet              @relation(fields: [betId], references: [id])
  filedBy  User             @relation("DisputeFiler", fields: [filedById], references: [id])
  messages DisputeMessage[]

  @@index([betId], map: "idx_dispute_bet")
  @@index([status], map: "idx_dispute_status")
  @@index([filedById], map: "idx_dispute_filed_by")
  @@map("disputes")
}

model DisputeMessage {
  id        String   @id @default(uuid()) @db.Uuid
  disputeId String   @map("dispute_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  dispute Dispute @relation(fields: [disputeId], references: [id])
  author  User    @relation(fields: [authorId], references: [id])

  @@index([disputeId, createdAt], map: "idx_dispute_msg_thread")
  @@map("dispute_messages")
}

// =============================================================================
// WEBHOOKS (outbound to game developers)
// =============================================================================

model WebhookConfig {
  id        String             @id @default(uuid()) @db.Uuid
  gameId    String             @map("game_id") @db.Uuid
  url       String             @db.VarChar(500)
  secret    String             @db.VarChar(255)
  events    WebhookEventType[]
  isActive  Boolean            @default(true) @map("is_active")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  game         Game                 @relation(fields: [gameId], references: [id])
  deliveryLogs WebhookDeliveryLog[]

  @@index([gameId], map: "idx_webhook_config_game")
  @@map("webhook_configs")
}

model WebhookDeliveryLog {
  id              String                @id @default(uuid()) @db.Uuid
  webhookConfigId String                @map("webhook_config_id") @db.Uuid
  betId           String?               @map("bet_id") @db.Uuid
  eventType       WebhookEventType      @map("event_type")
  payload         Json
  status          WebhookDeliveryStatus @default(PENDING)
  httpStatus      Int?                  @map("http_status")
  responseBody    String?               @map("response_body") @db.Text
  attemptCount    Int                   @default(0) @map("attempt_count")
  nextRetryAt     DateTime?             @map("next_retry_at")
  deliveredAt     DateTime?             @map("delivered_at")
  createdAt       DateTime              @default(now()) @map("created_at")

  webhookConfig WebhookConfig @relation(fields: [webhookConfigId], references: [id])
  bet           Bet?          @relation(fields: [betId], references: [id])

  @@index([webhookConfigId, createdAt], map: "idx_webhook_log_config")
  @@index([status, nextRetryAt], map: "idx_webhook_log_retry")
  @@index([betId], map: "idx_webhook_log_bet")
  @@map("webhook_delivery_logs")
}

// =============================================================================
// WIDGET SESSION (short-lived tokens for in-game widget)
// =============================================================================

model WidgetSession {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  gameId    String              @map("game_id") @db.Uuid
  tokenHash String              @unique @map("token_hash") @db.VarChar(255)
  status    WidgetSessionStatus @default(ACTIVE)
  ipAddress String?             @map("ip_address") @db.VarChar(45)
  expiresAt DateTime            @map("expires_at")
  createdAt DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([tokenHash], map: "idx_widget_session_token")
  @@index([userId, gameId], map: "idx_widget_session_user_game")
  @@index([expiresAt], map: "idx_widget_session_expires")
  @@map("widget_sessions")
}

// =============================================================================
// STRIPE EVENTS (idempotent processing of inbound Stripe webhooks)
// =============================================================================

model StripeEvent {
  id            String    @id @default(uuid()) @db.Uuid
  stripeEventId String    @unique @map("stripe_event_id") @db.VarChar(255)
  eventType     String    @map("event_type") @db.VarChar(255)
  payload       Json
  processed     Boolean   @default(false)
  processedAt   DateTime? @map("processed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([stripeEventId], map: "idx_stripe_event_id")
  @@index([processed, createdAt], map: "idx_stripe_event_unprocessed")
  @@map("stripe_events")
}

// =============================================================================
// DEVELOPER ESCROW CAPS
// =============================================================================

model DeveloperEscrowLimit {
  id                 String   @id @default(uuid()) @db.Uuid
  developerProfileId String   @unique @map("developer_profile_id") @db.Uuid
  maxTotalEscrow     Decimal  @default(50000) @map("max_total_escrow") @db.Decimal(14, 2)
  maxSingleBet       Decimal  @default(1000) @map("max_single_bet") @db.Decimal(14, 2)
  currentEscrow      Decimal  @default(0) @map("current_escrow") @db.Decimal(14, 2)
  tier               String   @default("STARTER") @db.VarChar(50)
  updatedAt          DateTime @updatedAt @map("updated_at")

  developerProfile DeveloperProfile @relation(fields: [developerProfileId], references: [id])

  @@map("developer_escrow_limits")
}

// =============================================================================
// ANOMALY DETECTION
// =============================================================================

model AnomalyAlert {
  id                 String        @id @default(uuid()) @db.Uuid
  developerProfileId String        @map("developer_profile_id") @db.Uuid
  gameId             String?       @map("game_id") @db.Uuid
  type               AnomalyType
  status             AnomalyStatus @default(DETECTED)
  severity           String        @db.VarChar(20)
  details            Json
  autoAction         String?       @map("auto_action") @db.VarChar(100)
  resolvedById       String?       @map("resolved_by_id") @db.Uuid
  resolvedAt         DateTime?     @map("resolved_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  @@index([developerProfileId, status], map: "idx_anomaly_developer_status")
  @@index([type, status], map: "idx_anomaly_type_status")
  @@index([createdAt], map: "idx_anomaly_created")
  @@map("anomaly_alerts")
}
