# ===========================================
# PlayStake Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# --- Database ---
DATABASE_URL="postgresql://playstake:playstake@localhost:5432/playstake"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Stripe (use test-mode keys for local dev) ---
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Google OAuth ---
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# --- Kick OAuth ---
# Get these from https://kick.com/settings/developer
# Redirect URI to register: ${NEXT_PUBLIC_APP_URL}/api/auth/kick/callback
KICK_CLIENT_ID="your-kick-client-id"
KICK_CLIENT_SECRET="your-kick-client-secret"
# AES-256 key for encrypting stored Kick access/refresh tokens.
# Generate with: openssl rand -hex 32
KICK_TOKEN_ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# --- Public (exposed to the browser) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
NEXT_PUBLIC_APP_URL="http://localhost:3000"

