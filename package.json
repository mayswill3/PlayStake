{
  "name": "playstake",
  "version": "1.0.0",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:reset": "npx prisma migrate reset",
    "db:studio": "npx prisma studio",
    "prisma:generate": "npx prisma generate",
    "prisma:format": "npx prisma format",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ledger": "vitest run tests/unit/ledger/",
    "test:auth": "vitest run tests/unit/auth/",
    "test:integration": "vitest run tests/integration/",
    "test:integration:watch": "vitest tests/integration/",
    "workers": "npx tsx src/workers/index.ts",
    "workers:dev": "npx tsx --watch src/workers/index.ts",
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "next lint",
    "widget:build": "npx tsx widget.build.ts",
    "widget:build:prod": "NODE_ENV=production npx tsx widget.build.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20"
  },
  "description": "Real-money peer-to-peer wagering platform for competitive games",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@prisma/pg-worker": "^6.9.0",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.9.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.4.0",
    "autoprefixer": "^10.4.27",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.4",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.3",
    "ioredis": "^5.10.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "otpauth": "^9.5.0",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "prisma": "^7.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stripe": "^20.4.1",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "vitest": "^4.0.18"
  }
}
